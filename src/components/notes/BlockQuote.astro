---
const { cite, author, work, medium } = Astro.props;

const mediumClass =
  typeof medium === "string" && medium.length > 0
    ? medium.toLowerCase()
    : undefined;

const attribution = work
  ? `${author}, <cite class=${medium}>${work}</cite>`
  : author;
---

{
  cite ? (
    <a href={cite} class="blockquote">
      <blockquote cite={cite}>
        <div class="quote">
          <slot />
        </div>

        <p class="attribution">
          {author}
          {work && (
            <>
              {", "}
              <cite class={mediumClass}>{work}</cite>
            </>
          )}
        </p>
      </blockquote>
    </a>
  ) : (
    <blockquote>
      <div class="quote">
        <slot />
      </div>

      <p class="attribution">
        {author}
        {work && (
          <>
            {", "}
            <cite class={mediumClass}>{work}</cite>
          </>
        )}
      </p>
    </blockquote>
  )
}

<style lang="scss">
  blockquote {
    color-scheme: light dark;
    --accent: light-dark(#999, #595959);
    --background: light-dark(#efefef, #252525);

    background-color: var(--background);
    border-color: var(--accent);
    border-style: solid none;
    border-width: 0.01em;

    margin: 2rem 0;
    padding: 1em;
    display: grid;
    grid-template-rows: 1fr;

    text-align: justify;
    hyphens: auto;
  }

  div {
    font-size: var(--font-large);
    font-weight: 200;
    font-variation-settings: "wdth" 62.5;
  }

  .attribution {
    font-size: var(--font-small);
    font-weight: 100;
    text-align: right;
  }
</style>

<style lang="scss" is:global>
  cite.essay,
  cite.article {
    font-style: normal;

    &::before {
      content: "“";
    }

    &::after {
      content: "”";
    }
  }
</style>
